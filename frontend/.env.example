# Datuma frontend — copy to `.env` and fill in.
# CRA only exposes vars prefixed with REACT_APP_ to the browser bundle.
# Never put secrets here. Anything in `.env` is shipped to every visitor.

# Where the API lives. Leave blank for local dev to use http://localhost:5001.
# Prod example: REACT_APP_API_URL=https://api.datuma.app
REACT_APP_API_URL=

# Clerk publishable key (pk_test_... in dev, pk_live_... in prod).
# This is safe to expose in the browser — Clerk treats it as public.
REACT_APP_CLERK_PUBLISHABLE_KEY=pk_test_...

# Sentry DSN (optional). Get one from sentry.io. Leave blank to disable.
REACT_APP_SENTRY_DSN=
