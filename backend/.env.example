# Datuma backend — copy to `.env` and fill in.
# Never commit `.env`. Rotate any value that leaks.

# --- Runtime ----------------------------------------------------------------
NODE_ENV=development                 # `production` on the deployed server
PORT=5001

# Comma-separated list of allowed CORS origins. In dev, leave blank to allow
# localhost. In prod, set to your real domain(s):
#   ALLOWED_ORIGINS=https://datuma.app,https://www.datuma.app
ALLOWED_ORIGINS=

# --- Database ---------------------------------------------------------------
# Postgres connection string. Required in production (server fails to boot
# without it). Local dev: postgres://datuma:datuma@localhost:5432/datuma
DATABASE_URL=

# --- Anthropic --------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# --- Clerk (auth) -----------------------------------------------------------
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# --- Stripe (billing) -------------------------------------------------------
# Use `sk_test_...` against the test dashboard locally. Switch to `sk_live_...`
# only in the production environment. Webhook secret is per-endpoint.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs. Create one Product → two recurring Prices (monthly + annual)
# per plan in the Stripe dashboard, then paste the price IDs here.
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_TEAM_MONTHLY=price_...
STRIPE_PRICE_TEAM_ANNUAL=price_...

# --- Error monitoring (optional but recommended in prod) -------------------
# Get a DSN from sentry.io (free tier is fine). Leave blank to disable.
SENTRY_DSN=

# --- Founder alert emails (optional) ----------------------------------------
# Resend account → API Keys → create one. Free tier = 100 emails/day.
# Until you verify datuma.app in Resend, you can leave NOTIFY_FROM_EMAIL blank
# and emails will be sent from `onboarding@resend.dev`.
RESEND_API_KEY=
NOTIFY_FROM_EMAIL=Datuma <notifications@datuma.app>
NOTIFY_TO_EMAIL=hello@datuma.app

# Clerk webhook signing secret. Dashboard → Webhooks → Add endpoint →
# point at https://api.datuma.app/api/webhooks/clerk, subscribe to `user.created`,
# then copy the signing secret here.
CLERK_WEBHOOK_SECRET=whsec_...
